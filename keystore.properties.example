# Copy to keystore.properties and fill in for local release signing.
# DO NOT commit keystore.properties (enforced by .gitignore).
# CI and F-Droid builds use env-var fallbacks in app/build.gradle.kts:
#   KEYSTORE_FILE / KEYSTORE_PASSWORD / KEY_ALIAS / KEY_PASSWORD

storeFile=/absolute/path/to/your/SigningKey.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
